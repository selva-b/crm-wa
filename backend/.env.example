# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_wa?schema=public

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@crm-wa.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Account Lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# Verification
VERIFICATION_TOKEN_EXPIRY_HOURS=24
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_MAX_RESENDS_PER_HOUR=5

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15

# WhatsApp (Baileys) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_ENCRYPTION_KEY=
