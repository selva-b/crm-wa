# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_wa?schema=public

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_SUPER_ADMIN_SECRET=your-super-admin-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@crm-wa.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Account Lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30

# Verification
VERIFICATION_TOKEN_EXPIRY_HOURS=24
VERIFICATION_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_MAX_RESENDS_PER_HOUR=5

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=15

# WhatsApp (Baileys) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_ENCRYPTION_KEY=

# Settings encryption — used to encrypt integration credentials at rest
# Generate key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate salt: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=
SETTINGS_ENCRYPTION_SALT=

# Super Admin Seed — REQUIRED before running prisma:seed in production
# Set a strong, unique password. The seed script will refuse to run without this.
SUPER_ADMIN_EMAIL=superadmin@wazelo.in
SUPER_ADMIN_PASSWORD=

# AI Provider — powers smart replies, summarization, sentiment, intent detection
# Supported providers (pick one):
#
#   Provider     | AI_PROVIDER  | Free Tier       | Example AI_MODEL                                  | Get Key At
#   -------------|--------------|-----------------|---------------------------------------------------|---------------------------
#   Groq         | groq         | Yes (generous)  | llama-3.3-70b-versatile, mixtral-8x7b-32768       | console.groq.com
#   Google Gemini| gemini       | 15 RPM free     | gemini-2.0-flash, gemini-1.5-flash                | aistudio.google.com
#   Mistral      | mistral      | Free tier       | mistral-small-latest, open-mistral-nemo            | console.mistral.ai
#   Together AI  | together     | $5 free credit  | meta-llama/Llama-3.3-70B-Instruct-Turbo           | api.together.xyz
#   OpenRouter   | openrouter   | Free models     | google/gemma-2-9b-it:free                         | openrouter.ai
#   Cerebras     | cerebras     | Free tier       | llama-3.3-70b                                     | cloud.cerebras.ai
#   HuggingFace  | huggingface  | Free tier       | meta-llama/Llama-3.1-8B-Instruct                  | huggingface.co/settings/tokens
#   Cohere       | cohere       | Trial keys      | command-r, command-r-plus                          | dashboard.cohere.com
#   OpenAI       | openai       | Paid            | gpt-4o-mini, gpt-4o                               | platform.openai.com
#   Anthropic    | anthropic    | Paid            | claude-sonnet-4-20250514                           | console.anthropic.com
#
AI_PROVIDER=groq
AI_API_KEY=gsk_your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile

# Razorpay (default payment provider — India-first INR billing)
# Get keys at: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Set in Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (secondary provider — used for renewal charges on Stripe customers)
# Get keys at: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set in Stripe Dashboard → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
