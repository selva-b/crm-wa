generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  LOCKED
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum WhatsAppSessionStatus {
  CONNECTING
  CONNECTED
  DISCONNECTED
  RECONNECTING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  STICKER
  LOCATION
  CONTACT
}

enum MessageStatus {
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  CLOSED
}

enum ContactSource {
  WHATSAPP
  MANUAL
  IMPORT
  API
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignAudienceType {
  ALL
  FILTERED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

enum AuditAction {
  // Auth actions
  USER_REGISTERED
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  LOGIN_SUCCESS
  LOGIN_FAILED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  LOGOUT
  SESSION_REVOKED
  TOKEN_REFRESHED

  // Org/User management actions (EPIC 2)
  USER_INVITED
  INVITATION_ACCEPTED
  INVITATION_REVOKED
  INVITATION_EXPIRED
  USER_CREATED
  USER_UPDATED
  USER_DISABLED
  USER_ENABLED
  USER_DELETED
  ROLE_CHANGED
  ORG_SETTINGS_UPDATED

  // WhatsApp session actions (EPIC 3)
  WHATSAPP_QR_GENERATED
  WHATSAPP_SESSION_CONNECTED
  WHATSAPP_SESSION_DISCONNECTED
  WHATSAPP_SESSION_RECONNECTING
  WHATSAPP_SESSION_FORCE_DISCONNECTED
  WHATSAPP_UNAUTHORIZED_ATTEMPT
  WHATSAPP_MESSAGE_SENT
  WHATSAPP_MESSAGE_FAILED

  // Messaging Engine actions (EPIC 5)
  MESSAGE_QUEUED
  MESSAGE_PROCESSING
  MESSAGE_DELIVERED
  MESSAGE_READ
  MESSAGE_RETRY
  MESSAGE_DEAD_LETTERED
  INCOMING_MESSAGE_RECEIVED
  INCOMING_MESSAGE_DUPLICATE_IGNORED
  RATE_LIMIT_EXCEEDED

  // Contact & Lead Management actions (EPIC 4)
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  CONTACT_MERGED
  CONTACT_ASSIGNED
  CONTACT_REASSIGNED
  CONTACT_STATUS_CHANGED
  CONTACT_NOTE_ADDED
  CONTACT_TAG_ADDED
  CONTACT_TAG_REMOVED
  CONTACT_AUTO_CREATED

  // Campaign Management actions (EPIC 6)
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  CAMPAIGN_SCHEDULED
  CAMPAIGN_STARTED
  CAMPAIGN_PAUSED
  CAMPAIGN_RESUMED
  CAMPAIGN_COMPLETED
  CAMPAIGN_FAILED
  CAMPAIGN_CANCELLED

  // Scheduling & Automation actions (EPIC 7)
  SCHEDULED_MESSAGE_CREATED
  SCHEDULED_MESSAGE_UPDATED
  SCHEDULED_MESSAGE_CANCELLED
  SCHEDULED_MESSAGE_EXECUTED
  SCHEDULED_MESSAGE_FAILED
  AUTOMATION_RULE_CREATED
  AUTOMATION_RULE_UPDATED
  AUTOMATION_RULE_ENABLED
  AUTOMATION_RULE_DISABLED
  AUTOMATION_RULE_DELETED
  AUTOMATION_EXECUTED
  AUTOMATION_FAILED

  // RBAC & Access Control actions (EPIC 8)
  PERMISSION_DENIED
  PERMISSION_GRANTED
  ROLE_PERMISSION_UPDATED
  CROSS_TENANT_ACCESS_BLOCKED

  // Subscription & Billing actions (EPIC 9)
  PLAN_CREATED
  PLAN_UPDATED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPGRADED
  SUBSCRIPTION_DOWNGRADE_SCHEDULED
  SUBSCRIPTION_DOWNGRADE_APPLIED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_GRACE_PERIOD_ENTERED
  SUBSCRIPTION_REACTIVATED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  PAYMENT_RETRY_SCHEDULED
  PAYMENT_REFUNDED
  INVOICE_GENERATED
  USAGE_LIMIT_REACHED
  USAGE_SOFT_LIMIT_WARNING
  USAGE_COUNTER_RESET

  // Notification actions (EPIC 11)
  NOTIFICATION_PREFERENCE_UPDATED

  // Settings & Configuration actions (EPIC 12)
  SETTING_UPDATED
  SETTING_DELETED
  FEATURE_FLAG_CREATED
  FEATURE_FLAG_UPDATED
  FEATURE_FLAG_DELETED
  INTEGRATION_CONFIG_CREATED
  INTEGRATION_CONFIG_UPDATED
  INTEGRATION_CONFIG_DELETED
  INTEGRATION_CONFIG_TESTED
  WEBHOOK_CREATED
  WEBHOOK_UPDATED
  WEBHOOK_DELETED
  WEBHOOK_TESTED
}

// ─────────────────────────────────────────────
// SCHEDULING & AUTOMATION ENUMS (EPIC 7)
// ─────────────────────────────────────────────

enum ScheduledMessageStatus {
  PENDING
  QUEUED
  SENT
  CANCELLED
  FAILED
}

enum AutomationTriggerType {
  MESSAGE_RECEIVED
  CONTACT_CREATED
  LEAD_STATUS_CHANGED
  TIME_BASED
  NO_REPLY
}

enum AutomationConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  IN
  NOT_IN
}

enum AutomationActionType {
  SEND_MESSAGE
  ASSIGN_CONTACT
  ADD_TAG
  UPDATE_STATUS
}

enum AutomationRuleStatus {
  ACTIVE
  INACTIVE
}

enum AutomationExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

// ─────────────────────────────────────────────
// SUBSCRIPTION & BILLING ENUMS (EPIC 9)
// ─────────────────────────────────────────────

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum UsageMetricType {
  MESSAGES_SENT
  ACTIVE_USERS
  WHATSAPP_SESSIONS
  CAMPAIGN_EXECUTIONS
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(255)
  timezone  String    @default("UTC") @db.VarChar(100)
  branding  Json?     @db.JsonB
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users                   User[]
  invitations             Invitation[]
  auditLogs               AuditLog[]
  whatsappSessions        WhatsAppSession[]
  messages                Message[]
  contacts                Contact[]
  conversations           Conversation[]
  deadLetterMessages      DeadLetterMessage[]
  campaigns               Campaign[]
  scheduledMessages       ScheduledMessage[]
  automationRules         AutomationRule[]
  rolePermissions         RolePermission[]
  subscriptions           Subscription[]
  usageRecords            UsageRecord[]
  payments                Payment[]
  invoices                Invoice[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  settings                Setting[]
  featureFlags            FeatureFlag[]
  integrationConfigs      IntegrationConfig[]
  webhooks                Webhook[]

  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  orgId               String     @map("org_id") @db.Uuid
  email               String     @unique @db.VarChar(320)
  passwordHash        String     @map("password_hash") @db.VarChar(255)
  firstName           String     @map("first_name") @db.VarChar(100)
  lastName            String     @map("last_name") @db.VarChar(100)
  role                UserRole   @default(EMPLOYEE)
  status              UserStatus @default(PENDING_VERIFICATION)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  emailVerifiedAt     DateTime?  @map("email_verified_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  organization            Organization             @relation(fields: [orgId], references: [id])
  sessions                Session[]
  verificationTokens      VerificationToken[]
  auditLogs               AuditLog[]
  whatsappSessions        WhatsAppSession[]
  ownedContacts           Contact[]                @relation("ContactOwner")
  createdCampaigns        Campaign[]               @relation("CampaignCreator")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  @@unique([email, deletedAt], name: "unique_email_active")
  @@index([orgId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([orgId, role, deletedAt])
  @@map("users")
}

// ─────────────────────────────────────────────
// INVITATION
// ─────────────────────────────────────────────

model Invitation {
  id          String           @id @default(uuid()) @db.Uuid
  orgId       String           @map("org_id") @db.Uuid
  email       String           @db.VarChar(320)
  role        UserRole         @default(EMPLOYEE)
  token       String           @unique @db.VarChar(255)
  status      InvitationStatus @default(PENDING)
  invitedById String           @map("invited_by_id") @db.Uuid
  expiresAt   DateTime         @map("expires_at")
  acceptedAt  DateTime?        @map("accepted_at")
  revokedAt   DateTime?        @map("revoked_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, email, status], name: "unique_pending_invite")
  @@index([token])
  @@index([orgId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

// ─────────────────────────────────────────────
// SESSION (Refresh Tokens)
// ─────────────────────────────────────────────

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  refreshToken String    @unique @map("refresh_token") @db.VarChar(512)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orgId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────
// VERIFICATION TOKEN (Email Verify + Password Reset)
// ─────────────────────────────────────────────

model VerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(255)
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  orgId      String?     @map("org_id") @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  targetType String?     @map("target_type") @db.VarChar(100)
  targetId   String?     @map("target_id") @db.VarChar(255)
  metadata   Json?       @db.JsonB
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.VarChar(512)
  traceId    String?     @map("trace_id") @db.VarChar(64)
  source     String?     @db.VarChar(50) // "api", "worker", "automation", "system"
  duration   Int?        @db.Integer // request duration in ms
  createdAt  DateTime    @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([traceId])
  @@index([orgId, action, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// SYSTEM METRIC SNAPSHOT (EPIC 10 — Metrics & Monitoring)
// ─────────────────────────────────────────────

model SystemMetricSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String?  @map("org_id") @db.Uuid
  metric    String   @db.VarChar(100) // e.g. "api_latency", "queue_depth", "error_rate"
  value     Float
  tags      Json?    @db.JsonB // { endpoint: "/contacts", method: "GET", statusCode: 200 }
  createdAt DateTime @default(now()) @map("created_at")

  @@index([metric, createdAt])
  @@index([orgId, metric, createdAt])
  @@index([createdAt])
  @@map("system_metric_snapshots")
}

// ─────────────────────────────────────────────
// ALERT RULE (EPIC 10 — Error Tracking & Alerting)
// ─────────────────────────────────────────────

model AlertRule {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(255)
  metric          String    @db.VarChar(100)
  condition       String    @db.VarChar(20) // "gt", "lt", "gte", "lte", "eq"
  threshold       Float
  windowSeconds   Int       @map("window_seconds")
  channels        Json      @db.JsonB // ["email", "webhook"]
  channelConfig   Json      @map("channel_config") @db.JsonB
  enabled         Boolean   @default(true)
  cooldownSeconds Int       @default(300) @map("cooldown_seconds")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  alerts AlertEvent[]

  @@index([metric, enabled])
  @@index([enabled])
  @@map("alert_rules")
}

// ─────────────────────────────────────────────
// ALERT EVENT (EPIC 10 — Alert History)
// ─────────────────────────────────────────────

model AlertEvent {
  id          String   @id @default(uuid()) @db.Uuid
  alertRuleId String   @map("alert_rule_id") @db.Uuid
  metric      String   @db.VarChar(100)
  value       Float
  threshold   Float
  message     String   @db.Text
  channels    Json     @db.JsonB
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id])

  @@index([alertRuleId])
  @@index([metric, createdAt])
  @@index([createdAt])
  @@map("alert_events")
}

// ─────────────────────────────────────────────
// WHATSAPP SESSION (EPIC 3)
// ─────────────────────────────────────────────

model WhatsAppSession {
  id              String                @id @default(uuid()) @db.Uuid
  orgId           String                @map("org_id") @db.Uuid
  userId          String                @map("user_id") @db.Uuid
  phoneNumber     String?               @map("phone_number") @db.VarChar(20)
  status          WhatsAppSessionStatus @default(CONNECTING)
  encryptedCreds  String?               @map("encrypted_creds") @db.Text
  lastActiveAt    DateTime?             @map("last_active_at")
  lastHeartbeatAt DateTime?             @map("last_heartbeat_at")
  reconnectCount  Int                   @default(0) @map("reconnect_count")
  idempotencyKey  String?               @unique @map("idempotency_key") @db.VarChar(255)
  disconnectedAt  DateTime?             @map("disconnected_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")

  organization Organization      @relation(fields: [orgId], references: [id])
  user         User              @relation(fields: [userId], references: [id])
  messages     Message[]
  authKeys     WhatsAppAuthKey[]
  campaigns    Campaign[]

  @@unique([userId, deletedAt], name: "unique_active_session_per_user")
  @@index([orgId])
  @@index([userId])
  @@index([status])
  @@index([orgId, status])
  @@index([lastHeartbeatAt])
  @@index([deletedAt])
  @@map("whatsapp_sessions")
}

// ─────────────────────────────────────────────
// MESSAGE (EPIC 3)
// ─────────────────────────────────────────────

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  orgId             String           @map("org_id") @db.Uuid
  sessionId         String           @map("session_id") @db.Uuid
  conversationId    String?          @map("conversation_id") @db.Uuid
  whatsappMessageId String?          @unique @map("whatsapp_message_id") @db.VarChar(255)
  direction         MessageDirection
  type              MessageType      @default(TEXT)
  status            MessageStatus    @default(QUEUED)
  contactPhone      String           @map("contact_phone") @db.VarChar(20)
  contactName       String?          @map("contact_name") @db.VarChar(255)
  body              String?          @db.Text
  mediaUrl          String?          @map("media_url") @db.VarChar(2048)
  mediaMimeType     String?          @map("media_mime_type") @db.VarChar(100)
  mediaSize         Int?             @map("media_size")
  metadata          Json?            @db.JsonB
  idempotencyKey    String?          @unique @map("idempotency_key") @db.VarChar(255)
  priority          Int              @default(0)
  retryCount        Int              @default(0) @map("retry_count")
  maxRetries        Int              @default(3) @map("max_retries")
  nextRetryAt       DateTime?        @map("next_retry_at")
  failedReason      String?          @map("failed_reason") @db.Text
  processingAt      DateTime?        @map("processing_at")
  sentAt            DateTime?        @map("sent_at")
  deliveredAt       DateTime?        @map("delivered_at")
  readAt            DateTime?        @map("read_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  deletedAt         DateTime?        @map("deleted_at")

  organization      Organization       @relation(fields: [orgId], references: [id])
  session           WhatsAppSession    @relation(fields: [sessionId], references: [id])
  conversation      Conversation?      @relation(fields: [conversationId], references: [id])
  events            MessageEvent[]
  campaignRecipient CampaignRecipient?

  @@index([orgId])
  @@index([sessionId])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([orgId, contactPhone])
  @@index([status])
  @@index([direction])
  @@index([createdAt])
  @@index([orgId, createdAt])
  @@index([deletedAt])
  @@index([sessionId, contactPhone, createdAt])
  @@index([status, nextRetryAt])
  @@index([orgId, status, direction])
  @@map("messages")
}

// ─────────────────────────────────────────────
// WHATSAPP AUTH KEY (EPIC 3 — Baileys Signal Protocol Keys)
// ─────────────────────────────────────────────

model WhatsAppAuthKey {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  keyType   String   @map("key_type") @db.VarChar(100)
  keyId     String   @map("key_id") @db.VarChar(255)
  keyData   String   @map("key_data") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, keyType, keyId], name: "unique_key_per_session")
  @@index([sessionId])
  @@index([sessionId, keyType])
  @@map("whatsapp_auth_keys")
}

// ─────────────────────────────────────────────
// CONTACT (EPIC 4 — Contact & Lead Management)
// ─────────────────────────────────────────────

model Contact {
  id           String        @id @default(uuid()) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  phoneNumber  String        @map("phone_number") @db.VarChar(20)
  name         String?       @db.VarChar(255)
  email        String?       @db.VarChar(320)
  avatarUrl    String?       @map("avatar_url") @db.VarChar(2048)
  source       ContactSource @default(WHATSAPP)
  leadStatus   LeadStatus    @default(NEW) @map("lead_status")
  ownerId      String        @map("owner_id") @db.Uuid
  sessionId    String?       @map("session_id") @db.Uuid
  metadata     Json?         @db.JsonB
  mergedIntoId String?       @map("merged_into_id") @db.Uuid
  optedOut     Boolean       @default(false) @map("opted_out")
  optedOutAt   DateTime?     @map("opted_out_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")

  organization       Organization           @relation(fields: [orgId], references: [id])
  owner              User                   @relation("ContactOwner", fields: [ownerId], references: [id])
  mergedInto         Contact?               @relation("ContactMerge", fields: [mergedIntoId], references: [id])
  mergedContacts     Contact[]              @relation("ContactMerge")
  statusHistory      ContactStatusHistory[]
  ownerHistory       ContactOwnerHistory[]
  contactTags        ContactTag[]
  notes              ContactNote[]
  campaignRecipients CampaignRecipient[]

  @@unique([orgId, phoneNumber, deletedAt], name: "unique_phone_per_org")
  @@index([orgId])
  @@index([phoneNumber])
  @@index([orgId, phoneNumber])
  @@index([ownerId])
  @@index([orgId, ownerId])
  @@index([leadStatus])
  @@index([orgId, leadStatus])
  @@index([source])
  @@index([createdAt])
  @@index([orgId, createdAt])
  @@index([deletedAt])
  @@index([mergedIntoId])
  @@index([orgId, name])
  @@map("contacts")
}

// ─────────────────────────────────────────────
// CONTACT STATUS HISTORY (EPIC 4)
// ─────────────────────────────────────────────

model ContactStatusHistory {
  id             String      @id @default(uuid()) @db.Uuid
  contactId      String      @map("contact_id") @db.Uuid
  orgId          String      @map("org_id") @db.Uuid
  previousStatus LeadStatus? @map("previous_status")
  newStatus      LeadStatus  @map("new_status")
  changedById    String      @map("changed_by_id") @db.Uuid
  reason         String?     @db.VarChar(500)
  createdAt      DateTime    @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([orgId])
  @@index([contactId, createdAt])
  @@map("contact_status_history")
}

// ─────────────────────────────────────────────
// CONTACT OWNER HISTORY (EPIC 4)
// ─────────────────────────────────────────────

model ContactOwnerHistory {
  id              String   @id @default(uuid()) @db.Uuid
  contactId       String   @map("contact_id") @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  previousOwnerId String?  @map("previous_owner_id") @db.Uuid
  newOwnerId      String   @map("new_owner_id") @db.Uuid
  assignedById    String   @map("assigned_by_id") @db.Uuid
  reason          String?  @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([orgId])
  @@index([contactId, createdAt])
