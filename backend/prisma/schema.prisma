  @@index([orgId])
  @@index([sessionId])
  @@index([contactPhone])
  @@index([orgId, status])
  @@index([lastMessageAt])
  @@index([orgId, lastMessageAt])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("conversations")
}

// ─────────────────────────────────────────────
