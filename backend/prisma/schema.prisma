generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  LOCKED
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum WhatsAppSessionStatus {
  CONNECTING
  CONNECTED
  DISCONNECTED
  RECONNECTING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  STICKER
  LOCATION
  CONTACT
  INTERACTIVE
}

enum MessageStatus {
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  CONVERTED
  CLOSED
}

enum ContactSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  MANUAL
  IMPORT
  API
