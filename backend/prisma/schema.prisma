// ─────────────────────────────────────────────
// MULTI-CHANNEL ENUMS (EPIC 16)
// ─────────────────────────────────────────────

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK_MESSENGER
  EMAIL
}

enum ChannelStatus {
  PENDING_SETUP
  VERIFYING
  ACTIVE
  SUSPENDED
