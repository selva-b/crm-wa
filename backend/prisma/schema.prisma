enum CampaignAudienceType {
  ALL
  FILTERED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum SequenceRecipientStatus {
  ACTIVE        // progressing through steps
  COMPLETED     // finished all steps
  EXITED        // left via exit condition (replied, etc.)
