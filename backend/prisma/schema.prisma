  name        String   @db.VarChar(255)
  description String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id])
  stages       PipelineStage[]
  deals        Deal[]

  @@index([orgId])
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid()) @db.Uuid
  pipelineId  String   @map("pipeline_id") @db.Uuid
  name        String   @db.VarChar(255)
  order       Int
  color       String?  @db.VarChar(20)
  isWonStage  Boolean  @default(false) @map("is_won_stage")
  isLostStage Boolean  @default(false) @map("is_lost_stage")
  createdAt   DateTime @default(now()) @map("created_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId, order])
  @@map("pipeline_stages")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id            String     @id @default(uuid()) @db.Uuid
  orgId         String     @map("org_id") @db.Uuid
  pipelineId    String     @map("pipeline_id") @db.Uuid
  stageId       String     @map("stage_id") @db.Uuid
  contactId     String     @map("contact_id") @db.Uuid
  assignedToId  String?    @map("assigned_to_id") @db.Uuid
  title         String     @db.VarChar(500)
  value         Decimal?   @db.Decimal(15, 2)
  currency      String     @default("INR") @db.VarChar(3)
  status        DealStatus @default(OPEN)
  expectedClose DateTime?  @map("expected_close")
  closedAt      DateTime?  @map("closed_at")
  notes         String?    @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  organization  Organization  @relation(fields: [orgId], references: [id])
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id])
  stage         PipelineStage @relation(fields: [stageId], references: [id])
  contact       Contact       @relation(fields: [contactId], references: [id])
  productId     String?       @map("product_id") @db.Uuid
  assignedTo    User?         @relation("DealAssignee", fields: [assignedToId], references: [id])
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([orgId])
  @@index([orgId, pipelineId])
  @@index([orgId, stageId])
  @@index([orgId, assignedToId])
  @@index([orgId, status])
  @@map("deals")
}

// ─────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  organization    Organization     @relation(fields: [orgId], references: [id])
  contactProducts ContactProduct[]
  deals           Deal[]
  csatSurveys     CsatSurvey[]
  articleProducts ArticleProduct[]

  @@unique([orgId, name, deletedAt])
  @@index([orgId])
  @@map("products")
}

model ContactProduct {
  id        String   @id @default(uuid()) @db.Uuid
  contactId String   @map("contact_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([contactId, productId])
  @@index([contactId])
  @@index([productId])
  @@map("contact_products")
}

// ─────────────────────────────────────────────
// TWO-FACTOR AUTHENTICATION
// ─────────────────────────────────────────────

model UserTwoFactor {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  encryptedSecret String    @map("encrypted_secret") @db.Text
  backupCodes     String[]  @map("backup_codes")                  // hashed codes
  enabledAt       DateTime  @default(now()) @map("enabled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_two_factors")
}

// ─────────────────────────────────────────────
// CHAT WIDGET (Phase 4)
// ─────────────────────────────────────────────

model WidgetConfig {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @unique @map("org_id") @db.Uuid
  enabled         Boolean  @default(false)
  position        String   @default("bottom-right") @db.VarChar(20) // bottom-right, bottom-left
  primaryColor    String   @default("#6366f1") @map("primary_color") @db.VarChar(20)
  welcomeMessage  String   @default("Hi! How can we help you?") @map("welcome_message") @db.VarChar(500)
  placeholder     String   @default("Type a message...") @db.VarChar(255)
  companyName     String?  @map("company_name") @db.VarChar(255)
  avatarUrl       String?  @map("avatar_url") @db.VarChar(2048)
  whatsappNumber  String?  @map("whatsapp_number") @db.VarChar(20) // pre-filled WhatsApp click-to-chat number
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("widget_configs")
}

// ─────────────────────────────────────────────
// GDPR CONSENT TRACKING (Phase 5)
// ─────────────────────────────────────────────

model ConsentRecord {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  contactId    String   @map("contact_id") @db.Uuid
  consentType  String   @map("consent_type") @db.VarChar(100) // e.g. "marketing", "messaging", "data_processing"
  granted      Boolean
  source       String   @db.VarChar(100) // e.g. "whatsapp_optin", "web_form", "manual", "import"
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  metadata     Json?    @db.JsonB
  grantedAt    DateTime @default(now()) @map("granted_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([orgId])
  @@index([orgId, consentType])
  @@index([contactId, consentType])
  @@map("consent_records")
}

model DataRequest {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  contactId    String   @map("contact_id") @db.Uuid
  requestType  String   @map("request_type") @db.VarChar(50) // "export" or "erasure"
  status       String   @default("pending") @db.VarChar(20) // pending, processing, completed, failed
  requestedById String  @map("requested_by_id") @db.Uuid
  completedAt  DateTime? @map("completed_at")
  resultUrl    String?  @map("result_url") @db.VarChar(2048) // S3 URL for export file
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([orgId])
  @@index([contactId])
  @@index([orgId, status])
  @@map("data_requests")
}

// ─────────────────────────────────────────────
// KNOWLEDGE BASE (Phase 5)
// ─────────────────────────────────────────────

model KbCategory {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @db.VarChar(255)
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])
  articles     KbArticle[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@map("kb_categories")
}

model KbArticle {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  categoryId  String?   @map("category_id") @db.Uuid
  title       String    @db.VarChar(500)
  slug        String    @db.VarChar(500)
  body        String    @db.Text // markdown content
  isPublished Boolean   @default(false) @map("is_published")
  isInternal  Boolean   @default(false) @map("is_internal") // internal-only (team KB)
  authorId    String    @map("author_id") @db.Uuid
  viewCount   Int       @default(0) @map("view_count")
  helpfulCount Int      @default(0) @map("helpful_count")
  tags        String[]  @default([])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization    Organization     @relation(fields: [orgId], references: [id])
  category        KbCategory?      @relation(fields: [categoryId], references: [id])
  author          User             @relation("ArticleAuthor", fields: [authorId], references: [id])
  articleProducts ArticleProduct[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([orgId, isPublished])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("kb_articles")
}

model ArticleProduct {
  id        String   @id @default(uuid()) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  article KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  product Product   @relation(fields: [productId], references: [id])

  @@unique([articleId, productId])
  @@index([articleId])
  @@index([productId])
  @@map("article_products")
}

model KbDocument {
  id            String    @id @default(uuid()) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  flowId        String?   @map("flow_id") @db.Uuid  // Link to chatbot flow (optional)
  title         String    @db.VarChar(255)
  filename      String    @db.VarChar(255)
  fileUrl       String    @map("file_url") @db.Text
  contentType   String    @map("content_type") @db.VarChar(100)
  fileSize      Int       @map("file_size")
  extractedText String?   @map("extracted_text") @db.Text
  status        String    @default("PROCESSING") @db.VarChar(20) // PROCESSING, READY, FAILED
  uploadedById  String    @map("uploaded_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id])
  uploadedBy   User         @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([orgId])
  @@index([orgId, flowId])
  @@index([orgId, status])
  @@map("kb_documents")
}

// ─────────────────────────────────────────────
// CUSTOM FIELDS (Phase 7)
// ─────────────────────────────────────────────

model CustomFieldDefinition {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  entity       String   @db.VarChar(50) // "contact", "deal", "conversation"
  fieldName    String   @map("field_name") @db.VarChar(100)
  fieldLabel   String   @map("field_label") @db.VarChar(255)
  fieldType    String   @map("field_type") @db.VarChar(30) // text, number, date, select, multiselect, boolean, url, email, phone
  options      Json?    @db.JsonB // For select/multiselect: ["option1", "option2"]
  isRequired   Boolean  @default(false) @map("is_required")
  defaultValue String?  @map("default_value") @db.VarChar(1000)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [orgId], references: [id])
  values       CustomFieldValue[]

  @@unique([orgId, entity, fieldName])
  @@index([orgId, entity])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  fieldId      String   @map("field_id") @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid // contactId, dealId, etc.
  value        String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([orgId, entityId])
  @@index([fieldId])
  @@map("custom_field_values")
}

// ─────────────────────────────────────────────
// DEVELOPER API KEYS (Phase 7)
// ─────────────────────────────────────────────

model ApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  name         String    @db.VarChar(255)
  keyHash      String    @unique @map("key_hash") @db.VarChar(255) // SHA-256 hash of key
  keyPrefix    String    @map("key_prefix") @db.VarChar(12) // First 8 chars for display (e.g. "crm_sk_a1b2...")
  scopes       String[]  @default(["read"]) // "read", "write", "contacts", "messages", "campaigns"
  expiresAt    DateTime? @map("expires_at")
  lastUsedAt   DateTime? @map("last_used_at")
  lastUsedIp   String?   @map("last_used_ip") @db.VarChar(45)
  isActive     Boolean   @default(true) @map("is_active")
  createdById  String    @map("created_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")

  organization Organization @relation(fields: [orgId], references: [id])
  createdBy    User         @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([keyHash])
  @@index([orgId, isActive])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// SUPER ADMIN
// ─────────────────────────────────────────────

model SuperAdmin {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(320)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  name         String        @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  ticketReplies TicketReply[]

  @@map("super_admins")
}

// ─────────────────────────────────────────────
// HELP TICKETS
// ─────────────────────────────────────────────

model HelpTicket {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  title       String         @db.VarChar(255)
  description String         @db.Text
  category    TicketCategory
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  closedAt    DateTime?      @map("closed_at")

  organization Organization  @relation(fields: [orgId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  replies      TicketReply[]

  @@index([orgId, status])
  @@index([status, createdAt])
  @@map("help_tickets")
}

model TicketReply {
  id           String      @id @default(uuid()) @db.Uuid
  ticketId     String      @map("ticket_id") @db.Uuid
  body         String      @db.Text
  userId       String?     @map("user_id") @db.Uuid
  superAdminId String?     @map("super_admin_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at")

  ticket       HelpTicket  @relation(fields: [ticketId], references: [id])
  user         User?       @relation("TicketReplyUser", fields: [userId], references: [id])
  superAdmin   SuperAdmin? @relation(fields: [superAdminId], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_replies")
}

